# DOMAIN_NAME is the primary domain name for the WordPress site
DOMAIN_NAME=example.com.br

# PROJECT_NAME is used to name volumes, docker services, and routers uniquely
PROJECT_NAME=example

# Database Credentials
MYSQL_PASSWORD=your_secure_password
MYSQL_ROOT_PASSWORD=your_secure_password
MYSQL_USER=your_user

#Email for Let's Encrypt
EMAIL=email@example.com

#Backup database
BACKUP_DATABASE=database.sql

#WP prefix
WORDPRESS_TABLE_PREFIX=wpog_

# Adminer Basic Auth (proteção de acesso via Traefik)
# Gere o hash com o comando abaixo e cole o resultado aqui:
# echo $(htpasswd -nb admin SUA_SENHA) | sed -e s/\$/\$\$/g
ADMINER_BASIC_AUTH=admin:$$apr1$$SUBSTITUA_PELO_HASH_GERADO
